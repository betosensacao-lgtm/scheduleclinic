# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Database
# Pooler (used by the app at runtime)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres
# Direct connection (used by Drizzle migrations — no pooler)
DIRECT_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# Resend (email)
RESEND_API_KEY=re_your_key
# Use "onboarding@resend.dev" for testing, or a verified domain in production
EMAIL_FROM=ScheduleClinic <onboarding@resend.dev>

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cron (protects /api/cron/reminders — Vercel Cron sends this as a Bearer token)
CRON_SECRET=change-me-to-a-long-random-string
