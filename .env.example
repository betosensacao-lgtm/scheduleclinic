# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Database
# Pooler (used by the app at runtime)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres
# Direct connection (used by Drizzle migrations — no pooler)
DIRECT_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# AI / LLM (Groq)
GROQ_API_KEY=gsk_your-groq-api-key
# Optional: override default model (meta-llama/llama-4-scout-17b-16e-instruct)
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
# Optional: model for structured data extraction
GROQ_EXTRACTION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Resend (email)
RESEND_API_KEY=re_your_key
# Use "onboarding@resend.dev" for testing, or a verified domain in production
EMAIL_FROM=ScheduleClinic <onboarding@resend.dev>

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cron (protects /api/cron/reminders — Vercel Cron sends this as a Bearer token)
CRON_SECRET=change-me-to-a-long-random-string

# Stripe (payments)
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret
# NEXT_PUBLIC_CLINIC_ID is the default clinic for billing. In production, derived from session.
NEXT_PUBLIC_CLINIC_ID=your-clinic-uuid

# WhatsApp Business API
WHATSAPP_API_URL=https://graph.facebook.com/v21.0
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_ACCESS_TOKEN=your-access-token
WHATSAPP_VERIFY_TOKEN=your-verify-token
WHATSAPP_BUSINESS_ACCOUNT_ID=your-business-account-id
